{
  "SystemName": "Tenebria",
  "ServerName": "",
  "Version": "0.0.0.1",
  "OpenApi": {
    "EnableApiDocument": true,
    "WebOpenApiUrl": "/swagger/v1/swagger.json",
    "KeycloakOpenApiUrl": "https://www.keycloak.org/docs-api/latest/rest-api/openapi.json"
  },
  "RedisCache": {
    "DefaultExpirationMinutes": 60,
    "ClearCacheOnStartup": false,
    "Tables": {
      //--- ... ---//
    }
  },
  "Database": {
  },
  "Keycloak": {
    "Issuer": "Tenebria",
    "MasterRealm": "master",
    "SigninAcsUrl": "",
    "SignoutAcsUrl": ""
  },
  "JwtToken": {
    "Issuer": "Tenebria",
    "Audience": "Tenebria",
    "TokenLifespan": 60 // minutes
  },
  "Job": {
    "QueueName": "TenebriaJobQueue",
    "QueueTimeoutSec": 3,
    "MaxRetryCount": 3
  },
  "Storage": {
    "FileUploadOptions": {
      "MaxSizeMB": 10,
      "AllowedExtensions": [ ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".png", ".jpg" ]
    }
  }
}
